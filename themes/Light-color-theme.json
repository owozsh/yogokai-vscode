  "tokenColors": [
    // RED
    {
      "scope": [
        "meta.function.parameter variable",
        "punctuation.definition.binding-pattern.array",
        "source.rust meta.type_params.rust",
        "entity.other.attribute-name.class",
        "entity.other.attribute-name punctuation.definition.entity",
        "source.tsx punctuation.section.embedded",
        "source.jsx punctuation.section.embedded",
        "invalid",
        "markup.deleted",
        "punctuation.separator.dictionary.key-value",
        "punctuation.definition.markdown",
        "storage.modifier.pointer",
        "punctuation.definition.typeparameters",
        "punctuation.definition.template-expression",
        "punctuation.definition.directive",
        "new.expr entity.name.type",
        "entity.other.inherited-class",
        "comment.block.documentation entity.name.type",
        "punctuation.definition.entity.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.class.css",
        "punctuation.definition.string.template",
        "support.constant.property-value",
        "keyword.operator",
        "storage.modifier",
        "keyword"
      ],
      "settings": {
        "foreground": "#e11d48",
        "fontStyle": ""
      }
    },
    // RED_ITALIC
    {
      "scope": [
        "keyword.other.unit",
        "variable.argument",
        "keyword.control",
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#e11d48",
        "fontStyle": "italic"
      }
    },
    // RED_BOLD
    {
      "scope": ["punctuation.definition.heading"],
      "settings": {
        "foreground": "#e11d48",
        "fontStyle": "bold"
      }
    },
    // ORANGE:
    {
      "scope": ["constant.numeric.css", "constant.numeric"],
      "settings": {
        "foreground": "#7c3aed",
        "fontStyle": ""
      }
    },
    // ORANGE_ITALIC
    {
      "scope": ["constant.language", "support.type.primitive"],
      "settings": {
        "foreground": "#7c3aed",
        "fontStyle": "italic"
      }
    },
    // ORANGE_BOLD
    {
      "scope": [],
      "settings": {
        "foreground": "#7c3aed",
        "fontStyle": "bold"
      }
    },
    // YELLOW:
    {
      "scope": [
        "string",
        "punctuation.definition.string",
        "constant.language.import-export-all",
        "meta.tag string",
        "markup.heading.setext",
        "meta.separator.markdown",
        "meta.property-value",
        "meta.property-value constant.other",
        "punctuation.section.embedded.begin.php",
        "punctuation.section.embedded.end.php",
        "markup.inserted",
        "string.template"
      ],
      "settings": {
        "foreground": "#ca8a04",
        "fontStyle": ""
      }
    },
    // YELLOW_ITALIC:
    {
      "scope": [],
      "settings": {
        "foreground": "#ca8a04",
        "fontStyle": "italic"
      }
    },
    // YELLOW_UNDERLINE
    {
      "scope": [],
      "settings": {
        "foreground": "#ca8a04",
        "fontStyle": "underline"
      }
    },
    // BLUE
    {
      "scope": [
        "constant.character.escape",
        "variable.language.special.self",
        "meta.tag.metadata.doctype string",
        "meta.tag.sgml.doctype",
        "markup.inline.raw",
        "meta.link punctuation.definition.string",
        "meta.image punctuation.definition.string",
        "entity.other.attribute-name.pseudo-element",
        "entity.other.attribute-name.pseudo-class",
        "meta.diff.range",
        "constant.other.color",
        "entity.name.type.class",
        "meta.property-name support.type.property-name",
        "entity.name.tag.css",
        "entity.name.tag.wildcard",
        "punctuation.accessor",
        "constant"
      ],
      "settings": {
        "foreground": "#2563eb",
        "fontStyle": ""
      }
    },
    // BLUE_UNDERLINE
    {
      "scope": [],
      "settings": {
        "foreground": "#2563eb",
        "fontStyle": "underline"
      }
    },
    // BLUE_ITALIC
    {
      "scope": [],
      "settings": {
        "foreground": "#2563eb",
        "fontStyle": "italic"
      }
    },
    // CYAN
    {
      "scope": [
        "variable.language.super",
        "constant.character.entity",
        "punctuation.definition.entity",
        "markup.quote",
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.id punctuation.definition.entity",
        "variable.parameter.url",
        "entity.name.section",
        "markup.changed",
        "meta.diff.header",
        "storage.type.function.arrow",
        "punctuation.definition.list"
      ],
      "settings": {
        "foreground": "#0369a1",
        "fontStyle": ""
      }
    },
    // CYAN_ITALIC
    {
      "scope": [
        "storage.type.function",
        "storage",
        "storage.type",
        "support.type",
        "support.class",
        "support.type.property-name.css",
        "support.type.property-name.json",
        "punctuation.support.type.property-name.begin.json",
        "punctuation.support.type.property-name.end.json"
      ],
      "settings": {
        "foreground": "#0369a1",
        "fontStyle": "italic"
      }
    },
    // CYAN_UNDERLINE
    {
      "scope": [
        "link",
        "markup.underline.link",
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#0369a1",
        "fontStyle": "underline"
      }
    },
    // GREEN
    {
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#047857",
        "fontStyle": ""
      }
    },
    // GREEN_ITALIC
    {
      "scope": [
        "punctuation.definition.entity.html",
        "constant.character.entity.named.emsp.html",
        "support.type.builtin",
        "meta.type.annotation entity.name.type",
        "meta.type.parameters entity.name.type",
        "meta.property-list entity.name.tag.css",
        "meta.tag entity.other.attribute-name",
        "entity.other.attribute-name.html",
        "entity.name.type.class",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#047857",
        "fontStyle": "italic"
      }
    },
    // OORANGE_ITALIC
    {
      "scope": ["parameter", "variable.language.this", "variable.parameter"],
      "settings": {
        "foreground": "#ea580c",
        "fontStyle": "italic"
      }
    },
    // WHITE
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "meta.template.expression",
        "variable",
        "punctuation.definition.variable",
        "support.variable.property.dom",
        "support.variable.dom",
        "support.variable.property",
        "punctuation.separator.parameter",
        "string.interpolated.pug variable",
        "punctuation",
        "meta.block",
        "variable.other.object.property",
        "meta.brace.round.js"
      ],
      "settings": {
        "foreground": "#292524"
      }
    },
    // WHITE_BOLD
    {
      "scope": ["entity.name.section.markdown"],
      "settings": {
        "foreground": "#292524",
        "fontStyle": "bold"
      }
    },
    // BLACK
    {
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#a8a29e"
      }
    },
    // BLACK_BOLD
    {
      "scope": [],
      "settings": {
        "foreground": "#a8a29e",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic", "variable.other.property"],
      "settings": {
        "fontStyle": "italic"
      }
    }
  ]
}
